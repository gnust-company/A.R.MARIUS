# Armarius — compose defaults. Copy to `.env` and override as needed.
#   cp .env.sample .env && docker compose up --build

# ── host ports ──────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8080

# ── database (Postgres) ─────────────────────────────────────────────────────
POSTGRES_USER=armarius
POSTGRES_PASSWORD=armarius
POSTGRES_DB=armarius

# ── shared artifact store (MinIO) ───────────────────────────────────────────
# The backend stores task outputs + media in MinIO (bucket `armarius`, created on
# boot). Internal-only by default (backend → minio:9000 over the compose network;
# no host ports published, so this won't clash with a local 9000/9001). Credentials:
MINIO_ROOT_USER=armarius
MINIO_ROOT_PASSWORD=armarius123
MINIO_BUCKET=armarius

# Where artifacts live: "minio" (the composed default) or "local" (backend
# filesystem — no MinIO needed). MINIO_ENDPOINT is the address the BACKEND dials;
# the default is the in-network minio service. Point it (plus the credentials
# above) at an external S3/MinIO to skip the bundled one. MINIO_SECURE=true for
# an https endpoint.
ARTIFACT_STORE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_SECURE=false

# ── URLs ────────────────────────────────────────────────────────────────────
# Public URL of the Armarius API that AGENTS call back into (claim/comment/publish).
# This is embedded into invitation prompts. When agents run on other machines, set
# this to an externally reachable origin (reverse proxy / public host), e.g.:
#   ARMARIUS_PUBLIC_URL=https://armarius.example.com
ARMARIUS_PUBLIC_URL=http://localhost:8080

# The frontend reaches the API on the SAME origin via nginx reverse-proxy, so NO
# absolute URL is baked into the bundle — the UI works behind any host/port/domain.
# Only set VITE_API_BASE (empty by default) if you run the API on a SEPARATE origin.
# NOTE: Vite bakes VITE_* in at image BUILD time — after changing them run
# `docker compose up -d --build frontend`, a plain restart won't pick them up.
#   VITE_API_BASE=https://api.armarius.example.com
VITE_API_BASE=

# Allowed CORS origins for the API ("*" for local dev, or your UI origin in prod).
CORS_ORIGINS=*

# ── user auth (JWT) ─────────────────────────────────────────────────────────
# Secret used to sign human-user access/refresh tokens. CHANGE THIS in production
# (use a long random string / secrets manager). Never commit a real secret.
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ── demo seed ───────────────────────────────────────────────────────────────
# ON by default for the composed showcase stack — seeds "Acme Web Platform" +
# Alice/Bob/Cleo/Dex + a loginable demo user (see ARMARIUS_DEMO_* below) on a fresh
# database. The seed is idempotent (skipped if any workspace already exists). Set
# false to start every new user on their own empty personal workspace instead.
ARMARIUS_SEED_DEMO=true

# The seed registers this demo Patron so the showcase journey is reachable end-to-end.
# Log in at the UI with ARMARIUS_DEMO_EMAIL / ARMARIUS_DEMO_PASSWORD.
ARMARIUS_DEMO_EMAIL=demo@acme.dev
ARMARIUS_DEMO_PASSWORD=demo1234
