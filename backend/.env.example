# Armarius backend configuration

ENVIRONMENT=dev

# SQLite (default, zero-setup) — or Postgres:
# postgresql+psycopg://postgres:postgres@localhost:5432/armarius
DATABASE_URL=sqlite+aiosqlite:///./armarius.db

# CORS (comma separated origins, or * for all in dev)
CORS_ORIGINS=*

# Local shared artifact store root
ARTIFACT_STORE_ROOT=./artifacts_store

# Wake engine: max continuation/nudge attempts before escalating to a human
WAKE_MAX_CONTINUATION_ATTEMPTS=3

# Default per-run liveness timeout (seconds) the Armarius watchdog enforces
RUN_TIMEOUT_SECONDS=900
